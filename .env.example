# --- MongoDB Atlas ---
MONGODB_URI=<your-mongodb-atlas-connection-string>
MONGODB_DB=tamubot

# --- Voyage AI (embeddings) ---
VOYAGE_API_KEY=

# --- TAMU AI API (OpenAI-compatible gateway — routes all RAG LLM calls) ---
# When set, USE_TAMU_API=True and all rag/ calls go through this gateway.
# Leave unset to fall back to direct Google API.
TAMU_API_KEY=
TAMU_BASE_URL=https://chat-api.tamu.ai/openai
TAMU_MODEL=protected.gemini-2.5-flash

# --- Google AI (Gemini for generation + query routing) ---
# Still required for ingestion_pipeline/process_syllabi.py (PDF multimodal).
# Used as fallback when TAMU_API_KEY is unset.
GOOGLE_API_KEY=

# --- Model ---
MODEL_NAME=gemini-2.5-flash

# --- Retrieval backend: "mongodb" (default) or "vertex" (legacy) ---
RETRIEVAL_BACKEND=mongodb

# --- GCP / Vertex AI (legacy fallback) ---
PROJECT_ID=
RETRIEVAL_REGION=us-south1
GENERATION_REGION=us-central1
RAG_CORPUS_RESOURCE_NAME=

# --- Observability ---
LANGSMITH_API_KEY=
APP_MODE=test

# --- Langfuse ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- API Proxy rate limits (used by tools/api-proxy when running in Docker) ---
API_PROXY_TAMU_RPM=30          # hard cap: requests/minute to TAMU API
API_PROXY_TAMU_SESSION=100     # per-session rolling budget for TAMU API
API_PROXY_VOYAGE_RPM=60        # hard cap: requests/minute to Voyage AI
API_PROXY_VOYAGE_SESSION=200   # per-session rolling budget for Voyage AI
GOOGLE_API_RPM=20              # code-level rate limiter for Google AI (PDF parsing)
